hildren:a,label:"Studios",link:{path:"/studios",slug:"studios",type:e},thumbnail:{alt:"Studios thumbnail",extension:r,height:i,type:t,uid:"m46zohhw",url:"https://cdn.sanity.io/images/zksivtxz/production/e0f23c4a965369ef9a7cc0752134c7f20afe27fc-180x140.jpg",width:n}},{children:a,label:"Recognition",link:{path:"/recognition",slug:"recognition",type:e},thumbnail:{alt:"Recognition thumbnail",extension:r,height:i,type:t,uid:"ls91vrb5",url:"https://cdn.sanity.io/images/zksivtxz/production/d1ff7a9536b62ecbb2062ab822b9395522055fc7-180x140.jpg",width:n}},{children:[{label:x,link:{path:"/branding",slug:"branding",type:e}},{label:"Naming",link:{path:"/naming",slug:"naming",type:e}}],label:"Work",link:{path:"/work",slug:"work",type:e},thumbnail:{alt:"Work thumbnail",extension:r,height:i,type:t,uid:"ls922zpz",url:"https://cdn.sanity.io/images/zksivtxz/production/b8bbee9bad2077bc6b43e6c31fc745baccc3b9c2-180x140.jpg",width:n}},{children:[{label:"Book",link:{type:o,url:"https://book.burocratik.com"}}],label:"18 Years of Büro",link:{type:o,url:"https://18.burocratik.com"},thumbnail:{alt:"18 years of Büro",extension:"webp",height:i,type:t,uid:"m8zxst5d",url:"https://cdn.sanity.io/images/zksivtxz/production/3f6758a3f933d88a3d3bec1c61900ec8a4b474de-180x140.webp",width:n}}],socials:[{label:z,link:{type:o,url:"https://linkedin.com/company/burocratik"}},{label:W,link:{type:o,url:B}},{label:q,link:{type:o,url:C}},{label:"Büro on X",link:{type:o,url:"https://twitter.com/burocratik"}}],tagline:"We are\nBüro"},letsTalkData:{form:{defaultMutations:{recommendedCaseStudies:{medium:{industry:"Real Estate",link:{path:"/work/kozowood",type:e},subtitle:S,tagline:"Made of Nature",thumbnail:{alt:"Kozowood thumbnail",extension:p,height:1760,type:t,uid:"lto6mdh6",url:"https://cdn.sanity.io/images/zksivtxz/production/3db67a6a6d7e71c564dc8c0462013828ff594f87-3320x1760.png",width:3320},title:"Kōzōwood",type:s},message:"Oh, and while you're at it, take a peek at our freshest case studies.",small:{industry:m,link:{path:"/work/clear-street",type:e},subtitle:"Rebranding & Website",tagline:"Designed for the Future.",thumbnail:{height:1320,mediaType:g,muted:b,sources:[{height:1320,type:g,url:"https://burosite.fra1.cdn.digitaloceanspaces.com/burocratik/2024-11-21T11-31-34.450Z-Sequence 05.mp4",width:1920},{height:880,type:g,url:"https://burosite.fra1.cdn.digitaloceanspaces.com/burocratik/2024-11-21T11-42-22.006Z-Sequence 05-mobile.mp4",width:1280}],type:"video",width:1920},title:"Clear Street",type:s}},subtitle:"Let's Rock!",title:"Solid! Your request is spot on, and we're set to go. Keep an eye on your inbox for our follow-up."},errorMessage:"You are not giving it all.\nSick of the red? Please, fill everything to proceed.",fields:[{label:"Brief Adriano on what you need:",multiple:b,name:"needs",options:[S,x,"Branding & Website","UI/UX Design","Motion Graphics",j],type:l},{label:"Budget Range (€)",multiple:d,name:A,options:["50k—100k","100k—200k",T],type:l},{label:"Your Company",name:"company",placeholder:"Your company",type:Y},{label:"Your Name",name:"name",placeholder:"Your name",type:Y},{label:"Your E-mail",name:D,placeholder:"Your e-mail",type:D},{label:"Project Details",name:"details",placeholder:"We're all ears! Dive deep into your project with us. Share your goals, expectations, success criteria, concerns, constraints, and any flexibility you have. The more you give us on the challenge, the better we can understand how to assist you.",type:"text"},{label:"Project Delivery Date",multiple:d,name:u,options:[P,"6 months","9 months",y],type:l},{label:"Where did you hear about us?",multiple:d,name:"where-did-you-find-us",options:["Awwwards",z,"Made by Büro project","Friend",j],type:l}],mutations:[{field:{name:A,value:T},type:w,value:"Now we are talking! Your request is precisely what we were hoping for. Keep an eye on your inbox for our follow-up. "},{field:{name:u,value:P},type:w,value:"You are crazier than us!  Let's turn those wild ideas into reality. Keep an eye on your inbox for our follow-up. "},{field:{name:u,value:y},type:w,value:"You're in it for the long haul! Let's shape those future plans into reality. Keep an eye on your inbox for our follow-up. "},{field:{name:u,value:y},type:"recommendedCaseStudies",value:{medium:{industry:m,link:{path:M,type:e},subtitle:N,tagline:R,thumbnail:{alt:c,extension:p,height:h,type:t,uid:I,url:E,width:h},title:c,type:s},small:{industry:m,link:{path:M,type:e},subtitle:N,tagline:R,thumbnail:{alt:c,extension:p,height:h,type:t,uid:I,url:E,width:h},title:c,type:s}}}],subtitle:K,title:"You've got it! Lay out all the juicy details for us. We want to hear more than just \"a new website\" – give us the scoop, and we'll be ready to jump 🚀 in as soon as possible!  "},metadata:{description:"So you want to know more?\nSweet, let’s talk!",image:a,keywords:a,name:K,path:_,slug:O,title:"Let's Talk with Büro!",unlisted:d},sections:[{name:"Faq",props:{items:[{answer:"We work with everyone from solo founders and small startups to Fortune 500 🤯 companies. If you've got an exciting project and a clear budget in place, we're all ears. Let's explore how we can help you thrive and elevate your business to the next level.",question:"What type of clients do you take on?"},{answer:"Crafting great websites isn't simple. If you're concerned about budget, we get it. Let's keep the conversation going. We're also open to exploring equity stock as a means to propel our 🜋 brand forward, potentially as part of the payroll structure.",question:"I only need a simple webpage, do you do that?"},{answer:"Absolutely. Just keep in mind that technically, a page with a logo can be called a Landing Page. Don’t expect too much from it—it’s more of a digital card than a full book. Many brands need a temporary page for a launch or event, and we often help with that. That said, we’ll decide what makes sense to include, and how. We get urgency. And we know how surprise requests hit later in the pipeline. You’re in good hands.",question:"We value quick delivery, can we have a Landing Page soon?"},{answer:"A logo? Not that much.\nA brand? A whole lot more. \nA fresh and robust visual identity? Now we are talking. \nWhat was your question again?",question:"I only need a logo! How much does a logo cost?"},{answer:"No, 🜑 sorry. We excel at problem-solving for clients who are already aware of our capabilities. However, if you're open to paying pitches or challenges to select your agency, we're ready to step up to the plate and offer you a taste of what lies ahead.",question:"Do you do visual pitches or public contests?"},{answer:"We've got a diverse portfolio spanning industries such as food and beverage, retail, technology, and fintech. But if your industry isn't listed, that's even better. We thrive on fresh challenges and refuse to beat the same old drum. Let's bring a new perspective to the table 🜂.",question:"What industries do you work with?"},{answer:"Absolutely, we're all about flexibility 🜐. As priorities shift, we can easily adjust your project team by adding or removing members. We've cultivated a trusted network of partners who share our commitment to delivering excellence. From copywriters to photographers, videographers, music and audio designers, chatgpt prompt wizards and 3D artists, we've got you covered.\n\nConsider us your long-term partner in digital strategy. Whether it's for the next few months or years, we'll be by your side every step of the way. At our core, we believe that staying small is the key to crafting impactful interactive content for brands, companies and products.",question:"Your team is small, but can you scale up to meet the demands of my substantial project?"},{answer:"Our stack is built on Headless CMS Sanity.io, JavaScript framework Vue.js, and Vue framework Nuxt.js, with hosting deployments managed through Vercel. For videos and other large assets that require significant bandwidth, we also utilize Spaces on Digital Ocean. While we can work with Webflow and WordPress, we do so only if absolutely necessary and when they offer something that our tech stack cannot deliver.",question:"What's your tech stack?"}],subtitle:"The Eight Golden Insights 🜅 to consider before partnering with Büro.\n",title:"FAQ"}},{name:"TestimonialShowcase",props:{description:"What our dear friends & clients said.",testimonials:[{endorser:{companyLogotype:{alt:"Remote",extension:f,height:100,type:t,uid:"m2c1sgah",url:"https://cdn.sanity.io/images/zksivtxz/production/3963f5e9ed5c9096672ffcd8f5060cb45800ef27-153x100.svg",width:153},name:"Leandro Peixoto",role:"Head of Design Remote.com"},quote:"When we decided to revamp the Remote website, the first agency that came to mind was Bürocratik. Their cutting-edge designs are always innovative while effortlessly incorporating motion and creating a unique fingerprint for our complex and extensive website.\nI highly recommend Bürocratik to companies seeking to take their online presence to the next level. Thank you, Büro team."},{endorser:{companyLogotype:{alt:a,extension:f,height:100,type:t,uid:"m3om0okh",url:"https://cdn.sanity.io/images/zksivtxz/production/c8405c5b2b7ccde30c2db0220c7fadb23a522ed2-121x100.svg",width:121},name:"Khalid Meniri 2",role:"Co-Founder & CEO, Selfbook"},quote:"Throughout our website relaunch process, Büro have lended an exceptionally creative eye to our brand identity and products, making our site engaging, interactive and sleek. At Selfbook, we value high-caliber design and innovation, and it was a significant win for us to find an agency we can see eye-to-eye with when it comes to bringing our design-driven brand to life. "},{endorser:{companyLogotype:{alt:"Ziqqi",extension:f,height:100,type:t,uid:"luyn2pkv",url:"https://cdn.sanity.io/images/zksivtxz/production/19dbff18f544123818e6f9fd0a0b804666f57d4d-124x100.svg",width:124},name:"Mohammed Ali",role:"Ziqqi Founder & CEO"},quote:"Bürocratik do everything right. Strategic, as well as tactical, responsive, and fast. We received hours upon hours of dedicated brand-building. From working with designers, and developers to copywriters and brand strategists. What we found particularly helpful was Büro's close attention to what we wanted our company to represent and what our business strategy was centered around. Büro went ahead and basically built us a Brand that exactly fits our identity and defines our vision to the world. We couldn't have asked for more and are very happy with the Büro client experience!"}],title:"Testimonials"}},{name:"footer",props:{contacts:[{label:"hello@burocratik.com",link:{type:o,url:"mailto:hello@burocratik.com"},purpose:"General questions"},{label:"Let's talk!",link:{path:_,type:e},purpose:"New business enquiries"}],socials:[{label:W,url:B},{label:q,url:C},{label:"Tumblr",url:"http://marks.burocratik.com/"},{label:"Vimeo",url:"https://vimeo.com/burocratik"},{label:"Behance",url:"https://www.behance.net/burocratik"},{label:"Dribbble",url:"https://dribbble.com/burocratik"},{label:"Medium",url:"https://medium.com/@Burocratik"},a,{label:"Awwwarded websites",url:"http://www.awwwards.com/burocratik/"}],studios:[{address:"Parque Emp. de Eiras\nLote 22\n3020-430 Coimbra\nPortugal",coordinates:"N 40° 14' 21.16\"\nW 8° 26' 3.84\"",url:"https://www.google.pt/maps/place/B%C3%BCrocratik+Coimbra/@40.2391766,-8.4681253,13z/data=!4m14!1m7!3m6!1s0xd22f92ec9504511:0xcde7aaff4083290a!2sB%C3%BCrocratik+Coimbra!8m2!3d40.2392688!4d-8.4344836!16s%2Fg%2F1tfbpltd!3m5!1s0xd22f92ec9504511:0xcde7aaff4083290a!8m2!3d40.2392688!4d-8.4344836!16s%2Fg%2F1tfbpltd?entry=ttu"},{address:"Rua de Alfredo Cunha\n133 3º Frt\n4450-023 Matosinhos\nPortugal",coordinates:"N 41° 11' 04\" \nW 8° 41' 35\"",url:"https://www.google.pt/maps/place/B%C3%BCrocratik+Porto/@41.1844989,-8.6848582,17z/data=!3m2!4b1!5s0xd246f47a833da01:0x1116db6997ed7a16!4m6!3m5!1s0xd246f2fded1eefb:0x410ce87bb9a00916!8m2!3d41.1844989!4d-8.6822833!16s%2Fg%2F11c1pcft2h?entry=ttu"}],tagline:"Lovely right?\nWe can do it for you ↓"}}],slug:O},loadingComponent:b,_app:{basePath:"/",assetsPath:"/_nuxt/",cdnURL:a}},staticAssetsBase:"/_nuxt/static/1783584881"}}("internal","image",null,"external",140,180,"jpg","case-study","select",!1,"delivery-date","Placeholder",1200,"png","Fintech & Crypto","video/mp4",!0,"next year","title","svg",0,0,"Branding","LinkedIn","Instagram","https://www.instagram.com/burocratik/","Facebook","https://www.facebook.com/Burocratik/","Website",0,0,"Other","budget","> 200k","string","email","3 months","/work/placeholder","Rebrand & Website","Scale across the Multiverse","lrtd5mia","https://cdn.sanity.io/images/zksivtxz/production/08866b6d5b938c0889f56cf56446af854b976574-1200x1200.png","Let's Talk","/lets-talk","lets-talk")</script>
